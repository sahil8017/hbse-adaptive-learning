# ─────────────────────────────────────────────────────────────────────────────
# Example environment file. Copy to `.env` and fill in real values.
# `.env` is gitignored; this template is safe to commit. NEVER put real secrets here.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ─────────────────────────────────────────────────────────────────
ENV=development
INSTANCE_ID=local-dev

# ── AI / LLM ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
GEMINI_API_KEY=your-gemini-api-key-here
YOUTUBE_API_KEY=your-youtube-data-api-v3-key-here

# ── Database (External Supabase / Postgres) ─────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
REPLICA_DATABASE_URL=

# ── Security ────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate-a-64-char-hex-string-with-secrets-token-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=30
JWT_REFRESH_EXPIRE_DAYS=90
ADMIN_SECRET=generate-with-python-secrets-token-hex-32
METRICS_BEARER_TOKEN=generate-with-python-secrets-token-hex-32

# ── Observability ───────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Firebase (auth) ─────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_WEB_API_KEY=your-firebase-web-api-key

# ── CORS / Frontend ─────────────────────────────────────────────────────────
# JSON array or comma-separated. In production set to your real domain(s) only.
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
FRONTEND_PUBLIC_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Supabase (frontend, public) ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here

# ── Cache ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Local paths ─────────────────────────────────────────────────────────────
EMBEDDING_MODEL_DIR=backend/app/model/paraphrase-multilingual-MiniLM-L12-v2
CHROMA_DIR=db/chroma
CURRICULUM_PATH=data/curriculum.json
TUTOR_CONFIG_PATH=data/tutor_config.json
ENGLISH_CONFIG_PATH=data/subject_english_config.json
HINDI_CONFIG_PATH=data/subject_hindi_config.json
SUBJECT_CATALOG_PATH=data/subject_catalog.json

# ── Startup behavior ────────────────────────────────────────────────────────
RAG_INGEST_ON_STARTUP=false
INIT_DB_SCHEMA_ON_STARTUP=true
ENABLE_PGVECTOR_SETUP=true
